<div
  class="collapsible-tabs full-width"
  style="
    --section-padding-top: {{ section.settings.section_padding_top }}px;
    --section-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --section-bg: {{ section.settings.section_bg }};
    --card-bg: {{ section.settings.card_bg }};
    --card-radius: {{ section.settings.card_radius }}px;
    --card-padding-desktop: {{ section.settings.card_padding_desktop }}px;
    --card-padding-mobile: {{ section.settings.card_padding_mobile }}px;
    --label-color: {{ section.settings.label_color }};
    --label-size: {{ section.settings.label_size }}px;
    --label-weight: {{ section.settings.label_weight }};
    --desktop-text-size: {{ section.settings.desktop_text_size }}px;
    --desktop-text-weight: {{ section.settings.desktop_text_weight }};
    --desktop-text-color: {{ section.settings.desktop_text_color }};
    --desktop-line-height: {{ section.settings.desktop_line_height }};
    --mobile-label-size: {{ section.settings.mobile_label_size }}px;
    --mobile-label-weight: {{ section.settings.mobile_label_weight }};
    --mobile-label-color: {{ section.settings.mobile_label_color }};
    --mobile-text-size: {{ section.settings.mobile_text_size }}px;
    --mobile-text-weight: {{ section.settings.mobile_text_weight }};
    --mobile-text-color: {{ section.settings.mobile_text_color }};
    --mobile-line-height: {{ section.settings.mobile_line_height }};
  "
>
  <div class="collapsible-tabs__container">
    <!-- Description & Features - Desktop -->
    <details class="collapsible-tabs__accordion collapsible-tabs__accordion--desktop">
      <summary class="collapsible-tabs__accordion-header">
        <span class="collapsible-tabs__accordion-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
          {{ section.settings.description_desktop_label }}
        </span>
        <span class="collapsible-tabs__accordion-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="collapsible-tabs__icon-h" x1="4" y1="10" x2="16" y2="10"/>
            <line class="collapsible-tabs__icon-v" x1="10" y1="4" x2="10" y2="16"/>
          </svg>
        </span>
      </summary>
      <div class="collapsible-tabs__content">
        {%- if product.metafields.custom.collapsible_description != blank -%}
          {{ product.metafields.custom.collapsible_description | metafield_tag }}
        {%- else -%}
          {{ section.settings.description_fallback_text }}
        {%- endif -%}
      </div>
    </details>

    <!-- Description & Features - Mobile -->
    <details class="collapsible-tabs__accordion collapsible-tabs__accordion--mobile">
      <summary class="collapsible-tabs__accordion-header">
        <span class="collapsible-tabs__accordion-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
          {{ section.settings.description_mobile_label }}
        </span>
        <span class="collapsible-tabs__accordion-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="collapsible-tabs__icon-h" x1="4" y1="10" x2="16" y2="10"/>
            <line class="collapsible-tabs__icon-v" x1="10" y1="4" x2="10" y2="16"/>
          </svg>
        </span>
      </summary>
      <div class="collapsible-tabs__content">
        {%- if product.metafields.custom.collapsible_description != blank -%}
          {{ product.metafields.custom.collapsible_description | metafield_tag }}
        {%- else -%}
          {{ section.settings.description_fallback_text }}
        {%- endif -%}
      </div>
    </details>

    <!-- Shipping & Returns - Desktop -->
    <details class="collapsible-tabs__accordion collapsible-tabs__accordion--desktop">
      <summary class="collapsible-tabs__accordion-header">
        <span class="collapsible-tabs__accordion-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          {{ section.settings.shipping_desktop_label }}
        </span>
        <span class="collapsible-tabs__accordion-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="collapsible-tabs__icon-h" x1="4" y1="10" x2="16" y2="10"/>
            <line class="collapsible-tabs__icon-v" x1="10" y1="4" x2="10" y2="16"/>
          </svg>
        </span>
      </summary>
      <div class="collapsible-tabs__content">
        {{ section.settings.shipping_content }}
      </div>
    </details>

    <!-- Shipping & Returns - Mobile -->
    <details class="collapsible-tabs__accordion collapsible-tabs__accordion--mobile">
      <summary class="collapsible-tabs__accordion-header">
        <span class="collapsible-tabs__accordion-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          {{ section.settings.shipping_mobile_label }}
        </span>
        <span class="collapsible-tabs__accordion-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="collapsible-tabs__icon-h" x1="4" y1="10" x2="16" y2="10"/>
            <line class="collapsible-tabs__icon-v" x1="10" y1="4" x2="10" y2="16"/>
          </svg>
        </span>
      </summary>
      <div class="collapsible-tabs__content">
        {{ section.settings.shipping_content }}
      </div>
    </details>
  </div>
</div>

{% stylesheet %}
  .collapsible-tabs {
    background: var(--section-bg);
    padding: var(--section-padding-top) 0 var(--section-padding-bottom) 0;
  }

  .collapsible-tabs__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Desktop Accordion */
  .collapsible-tabs__accordion--desktop {
    display: block;
    background: var(--card-bg);
    border-radius: var(--card-radius);
  }

  .collapsible-tabs__accordion--mobile {
    display: none;
  }

  .collapsible-tabs__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--card-padding-desktop);
    cursor: pointer;
    list-style: none;
  }

  .collapsible-tabs__accordion-header::-webkit-details-marker {
    display: none;
  }

  .collapsible-tabs__accordion-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    color: var(--label-color);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .collapsible-tabs__accordion-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #999;
  }

  .collapsible-tabs__icon-v {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .collapsible-tabs__accordion[open] .collapsible-tabs__icon-v {
    opacity: 0;
    transform: scaleY(0);
  }

  .collapsible-tabs__content {
    padding: 0 var(--card-padding-desktop) var(--card-padding-desktop);
    font-size: var(--desktop-text-size);
    font-weight: var(--desktop-text-weight);
    color: var(--desktop-text-color);
    line-height: var(--desktop-line-height);
    text-align: center;
  }

  @media (max-width: 768px) {
    .collapsible-tabs {
      padding: var(--section-padding-top) 0 var(--section-padding-bottom) 0;
    }

    .collapsible-tabs__container {
      padding: 0;
      gap: 0;
    }

    .collapsible-tabs__accordion--desktop {
      display: none;
    }

    .collapsible-tabs__accordion--mobile {
      display: block;
      background: var(--card-bg);
      border-radius: 0;
    }

    .collapsible-tabs__accordion-header {
      padding: 16px;
    }

    .collapsible-tabs__accordion-title {
      font-size: var(--mobile-label-size);
      font-weight: var(--mobile-label-weight);
      color: var(--mobile-label-color);
      letter-spacing: 0;
      text-transform: none;
    }

    .collapsible-tabs__content {
      padding: 0 16px 16px;
      font-size: var(--mobile-text-size);
      font-weight: var(--mobile-text-weight);
      color: var(--mobile-text-color);
      line-height: var(--mobile-line-height);
      text-align: left;
    }
  }
{% endstylesheet %}

