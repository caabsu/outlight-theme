{%- liquid
  assign installation_metafield = product.metafields.custom.installation_guide
  assign description_metafield = product.metafields.custom.collapsible_description

  assign show_electrician_warning = false
  for collection in section.settings.electrician_collections
    if product.collections contains collection
      assign show_electrician_warning = true
      break
    endif
  endfor
-%}

<div
  class="amber-tabs full-width"
  style="
    --at-section-bg: {{ section.settings.section_bg }};
    --at-padding-top: {{ section.settings.section_padding_top }}px;
    --at-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --at-accent: {{ section.settings.accent_color }};
    --at-accent-bg: {{ section.settings.accent_bg_color }};
    --at-number-size: {{ section.settings.number_size }}px;
    --at-label-size: {{ section.settings.label_size }}px;
    --at-label-color: {{ section.settings.label_color }};
    --at-label-weight: {{ section.settings.label_weight }};
    --at-border-color: {{ section.settings.border_color }};
    --at-bottom-border-color: {{ section.settings.bottom_border_color }};
    --at-icon-color: {{ section.settings.icon_color }};
    --at-text-size: {{ section.settings.text_size }}px;
    --at-text-color: {{ section.settings.text_color }};
    --at-text-size-mobile: {{ section.settings.text_size_mobile }}px;
    --at-warning-bg: {{ section.settings.warning_bg }};
    --at-warning-text-color: {{ section.settings.warning_text_color }};
    --at-warning-icon-color: {{ section.settings.warning_icon_color }};
  "
>
  <div class="amber-tabs__container">
    {%- comment -%} 01 — Installation {%- endcomment -%}
    <details class="amber-tabs__item">
      <summary class="amber-tabs__header">
        <div class="amber-tabs__header-left">
          <span class="amber-tabs__number">01</span>
          <span class="amber-tabs__label">{{ section.settings.installation_label }}</span>
        </div>
        <span class="amber-tabs__icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="amber-tabs__icon-h" x1="3" y1="9" x2="15" y2="9"/>
            <line class="amber-tabs__icon-v" x1="9" y1="3" x2="9" y2="15"/>
          </svg>
        </span>
      </summary>
      <div class="amber-tabs__content">
        <div class="amber-tabs__body">
          {%- if installation_metafield != blank -%}
            {{ installation_metafield | metafield_tag }}
          {%- else -%}
            {{ section.settings.installation_fallback }}
          {%- endif -%}
        </div>
        {%- if show_electrician_warning -%}
          <div class="amber-tabs__warning">
            <span class="amber-tabs__warning-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
            </span>
            <span class="amber-tabs__warning-text">{{ section.settings.electrician_warning_text }}</span>
          </div>
        {%- endif -%}
      </div>
    </details>

    {%- comment -%} 02 — Description & Features {%- endcomment -%}
    <details class="amber-tabs__item">
      <summary class="amber-tabs__header">
        <div class="amber-tabs__header-left">
          <span class="amber-tabs__number">02</span>
          <span class="amber-tabs__label">{{ section.settings.description_label }}</span>
        </div>
        <span class="amber-tabs__icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="amber-tabs__icon-h" x1="3" y1="9" x2="15" y2="9"/>
            <line class="amber-tabs__icon-v" x1="9" y1="3" x2="9" y2="15"/>
          </svg>
        </span>
      </summary>
      <div class="amber-tabs__content">
        <div class="amber-tabs__body">
          {%- if description_metafield != blank -%}
            {{ description_metafield | metafield_tag }}
          {%- else -%}
            {{ section.settings.description_fallback }}
          {%- endif -%}
        </div>
      </div>
    </details>

    {%- comment -%} 03 — Shipping & Returns {%- endcomment -%}
    <details class="amber-tabs__item">
      <summary class="amber-tabs__header">
        <div class="amber-tabs__header-left">
          <span class="amber-tabs__number">03</span>
          <span class="amber-tabs__label">{{ section.settings.shipping_label }}</span>
        </div>
        <span class="amber-tabs__icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line class="amber-tabs__icon-h" x1="3" y1="9" x2="15" y2="9"/>
            <line class="amber-tabs__icon-v" x1="9" y1="3" x2="9" y2="15"/>
          </svg>
        </span>
      </summary>
      <div class="amber-tabs__content">
        <div class="amber-tabs__body">
          {{ section.settings.shipping_content }}
        </div>
      </div>
    </details>

  </div>
</div>

{% stylesheet %}
  .amber-tabs {
    background: var(--at-section-bg, #f7f5f0);
    padding: var(--at-padding-top, 0) 0 var(--at-padding-bottom, 32px) 0;
  }

  .amber-tabs__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  /* Each accordion item */
  .amber-tabs__item {
    border-top: 1px solid var(--at-border-color, #d6d3d1);
  }

  /* Header row */
  .amber-tabs__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 16px;
    cursor: pointer;
    list-style: none;
    transition: background-color 0.2s ease;
  }

  .amber-tabs__header::-webkit-details-marker {
    display: none;
  }

  .amber-tabs__header-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  /* Number */
  .amber-tabs__number {
    font-family: var(--font-heading-family), serif;
    font-size: var(--at-number-size, 14px);
    font-weight: 400;
    color: var(--at-accent, #d97706);
    min-width: 24px;
  }

  /* Label */
  .amber-tabs__label {
    font-family: var(--font-body-family), sans-serif;
    font-size: var(--at-label-size, 13px);
    font-weight: var(--at-label-weight, 600);
    color: var(--at-label-color, #1c1917);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* Icon */
  .amber-tabs__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--at-icon-color, #999);
  }

  .amber-tabs__icon-v {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* Open state — amber bg on header */
  .amber-tabs__item[open] > .amber-tabs__header {
    background-color: var(--at-accent-bg, rgba(217, 119, 6, 0.08));
  }

  .amber-tabs__item[open] .amber-tabs__icon-v {
    opacity: 0;
    transform: scaleY(0);
  }

  /* Content area */
  .amber-tabs__content {
    padding: 0 16px 24px 60px;
  }

  /* Body text with left amber accent border */
  .amber-tabs__body {
    border-left: 3px solid var(--at-accent, #d97706);
    padding-left: 20px;
    font-family: var(--font-body-family), sans-serif;
    font-size: var(--at-text-size, 16px);
    font-style: normal;
    font-weight: 400;
    color: var(--at-text-color, #44403c);
    line-height: 1.7;
  }

  .amber-tabs__body p {
    margin: 0;
  }

  .amber-tabs__body p + p {
    margin-top: 1em;
  }

  .amber-tabs__body > *:first-child {
    margin-top: 0;
  }

  /* Electrician warning */
  .amber-tabs__warning {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    margin-left: 23px;
    padding: 12px 16px;
    background: var(--at-warning-bg, #ffffff);
  }

  .amber-tabs__warning-icon {
    display: flex;
    align-items: center;
    color: var(--at-warning-icon-color, #d97706);
    flex-shrink: 0;
  }

  .amber-tabs__warning-text {
    font-family: var(--font-body-family), sans-serif;
    font-size: 14px;
    color: var(--at-warning-text-color, #1a1a1a);
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .amber-tabs__header {
      padding: 18px 12px;
    }

    .amber-tabs__header-left {
      gap: 16px;
    }

    .amber-tabs__number {
      font-size: 13px;
      min-width: 20px;
    }

    .amber-tabs__label {
      font-size: 12px;
      letter-spacing: 0.1em;
    }

    .amber-tabs__content {
      padding: 0 12px 20px 48px;
    }

    .amber-tabs__body {
      font-size: var(--at-text-size-mobile, 14px);
      padding-left: 16px;
    }

    .amber-tabs__warning {
      margin-left: 19px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collapsible_tabs.name",
  "settings": [
    {
      "type": "header",
      "content": "Installation"
    },
    {
      "type": "text",
      "id": "installation_label",
      "label": "Installation label",
      "default": "INSTALLATION"
    },
    {
      "type": "textarea",
      "id": "installation_fallback",
      "label": "Installation fallback text",
      "info": "Shown if custom.installation_guide metafield is empty",
      "default": "Secure the fixture to an exterior wall and connect it to AC power (85–265 V). Use proper weather-sealing at all junctions to maintain water resistance."
    },
    {
      "type": "collection_list",
      "id": "electrician_collections",
      "label": "Collections requiring electrician",
      "info": "Products in these collections will show the electrician warning"
    },
    {
      "type": "text",
      "id": "electrician_warning_text",
      "label": "Electrician warning text",
      "default": "Qualified electrician recommended for safe installation."
    },
    {
      "type": "header",
      "content": "Description & features"
    },
    {
      "type": "text",
      "id": "description_label",
      "label": "Description label",
      "default": "DESCRIPTION & FEATURES"
    },
    {
      "type": "textarea",
      "id": "description_fallback",
      "label": "Description fallback text",
      "info": "Shown if custom.collapsible_description metafield is empty",
      "default": "Crafted with premium materials and meticulous attention to detail. Each piece combines form and function for a truly distinctive lighting experience."
    },
    {
      "type": "header",
      "content": "Shipping & returns"
    },
    {
      "type": "text",
      "id": "shipping_label",
      "label": "Shipping label",
      "default": "SHIPPING & RETURNS"
    },
    {
      "type": "textarea",
      "id": "shipping_content",
      "label": "Shipping content",
      "default": "Free standard shipping on all orders. Express shipping available at checkout. We offer a 30-day risk-free return policy — if you're not satisfied, return in original packaging for a full refund."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f7f5f0"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (numbers, border)",
      "default": "#d97706"
    },
    {
      "type": "color",
      "id": "accent_bg_color",
      "label": "Active header background",
      "default": "#faefe0"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1c1917"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#d6d3d1"
    },
    {
      "type": "color",
      "id": "bottom_border_color",
      "label": "Bottom border color",
      "default": "#1c1917"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#44403c"
    },
    {
      "type": "color",
      "id": "warning_bg",
      "label": "Warning background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "warning_text_color",
      "label": "Warning text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "warning_icon_color",
      "label": "Warning icon color",
      "default": "#d97706"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Number size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body text size (desktop)",
      "min": 14,
      "max": 22,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Body text size (mobile)",
      "min": 12,
      "max": 18,
      "step": 1,
      "default": 14,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible_tabs.name"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
