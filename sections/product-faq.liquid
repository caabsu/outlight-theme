{%- comment -%}
  Product FAQ Section - Accordion layout for product page
  Supports up to 6 configurable FAQ items via section settings.
  Can also pull content from product metafield: custom.collapsible_description
{%- endcomment -%}

{%- liquid
  assign metafield_content = product.metafields.custom.collapsible_description
-%}

<div
  class="product-faq full-width"
  style="
    --faq-section-bg: {{ section.settings.section_bg }};
    --faq-padding-top: {{ section.settings.section_padding_top }}px;
    --faq-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --faq-title-size: {{ section.settings.title_size }}px;
    --faq-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --faq-title-color: {{ section.settings.title_color }};
    --faq-title-weight: {{ section.settings.title_weight }};
    --faq-question-size: {{ section.settings.question_size }}px;
    --faq-question-size-mobile: {{ section.settings.question_size_mobile }}px;
    --faq-question-color: {{ section.settings.question_color }};
    --faq-question-weight: {{ section.settings.question_weight }};
    --faq-answer-size: {{ section.settings.answer_size }}px;
    --faq-answer-size-mobile: {{ section.settings.answer_size_mobile }}px;
    --faq-answer-color: {{ section.settings.answer_color }};
    --faq-answer-weight: {{ section.settings.answer_weight }};
    --faq-border-color: {{ section.settings.border_color }};
    --faq-icon-color: {{ section.settings.icon_color }};
  "
>
  <div class="product-faq__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-faq__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="product-faq__list">
      {%- comment -%} Metafield content (rendered first if present) {%- endcomment -%}
      {%- if metafield_content != blank -%}
        <div class="product-faq__metafield-content">
          {{ metafield_content | metafield_tag }}
        </div>
      {%- endif -%}

      {%- comment -%} FAQ item 1 {%- endcomment -%}
      {%- if section.settings.question_1 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_1 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_1 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} FAQ item 2 - Dynamic product title {%- endcomment -%}
      {%- if section.settings.question_2 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_2 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_2 | replace: '[product_name]', product.title }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} FAQ item 3 {%- endcomment -%}
      {%- if section.settings.question_3 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_3 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_3 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} FAQ item 4 {%- endcomment -%}
      {%- if section.settings.question_4 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_4 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_4 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} FAQ item 5 {%- endcomment -%}
      {%- if section.settings.question_5 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_5 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_5 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} FAQ item 6 {%- endcomment -%}
      {%- if section.settings.question_6 != blank -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <span class="product-faq__question-text">{{ section.settings.question_6 }}</span>
            <span class="product-faq__icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="4" y1="10" x2="16" y2="10"/>
                <line class="product-faq__icon-v" x1="10" y1="4" x2="10" y2="16"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_6 }}</p>
          </div>
        </details>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .product-faq {
    background-color: var(--faq-section-bg, #f7f5f0);
    padding: var(--faq-padding-top, 48px) 0 var(--faq-padding-bottom, 48px) 0;
  }

  .product-faq__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--page-margin, 24px);
  }

  .product-faq__title {
    font-family: var(--font-heading-family), serif;
    font-style: var(--font-heading-style, normal);
    font-size: var(--faq-title-size, 28px);
    font-weight: var(--faq-title-weight, 500);
    color: var(--faq-title-color, #1c1917);
    text-align: center;
    margin: 0 0 40px 0;
    line-height: 1.2;
  }

  .product-faq__list {
    display: flex;
    flex-direction: column;
  }

  .product-faq__metafield-content {
    padding-bottom: 24px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--faq-border-color, #E7E5E4);
    font-family: var(--font-primary-family), sans-serif;
    font-size: var(--faq-answer-size, 14px);
    font-weight: var(--faq-answer-weight, 400);
    color: var(--faq-answer-color, #57534E);
    line-height: 1.7;
  }

  .product-faq__item {
    border-bottom: 1px solid var(--faq-border-color, #E7E5E4);
  }

  .product-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .product-faq__question::-webkit-details-marker {
    display: none;
  }

  .product-faq__question-text {
    font-family: var(--font-primary-family), sans-serif;
    font-size: var(--faq-question-size, 15px);
    font-weight: var(--faq-question-weight, 500);
    color: var(--faq-question-color, #1c1917);
    line-height: 1.4;
  }

  .product-faq__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--faq-icon-color, #78716C);
    transition: color 0.2s ease;
  }

  .product-faq__icon-h,
  .product-faq__icon-v {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .product-faq__item[open] .product-faq__icon-v {
    opacity: 0;
    transform: scaleY(0);
  }

  .product-faq__answer {
    padding: 0 0 24px 0;
    overflow: hidden;
  }

  .product-faq__answer p {
    font-family: var(--font-primary-family), sans-serif;
    font-size: var(--faq-answer-size, 14px);
    font-weight: var(--faq-answer-weight, 400);
    color: var(--faq-answer-color, #57534E);
    line-height: 1.7;
    margin: 0;
  }

  /* Hover state */
  .product-faq__question:hover .product-faq__question-text {
    color: var(--faq-question-color, #1c1917);
    opacity: 0.8;
  }

  .product-faq__question:hover .product-faq__icon {
    color: var(--faq-question-color, #1c1917);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .product-faq {
      padding: 32px 0;
    }

    .product-faq__container {
      max-width: 100%;
      padding: 0 20px;
    }

    .product-faq__title {
      font-size: var(--faq-title-size-mobile, 22px);
      margin-bottom: 28px;
    }

    .product-faq__question {
      padding: 16px 0;
    }

    .product-faq__question-text {
      font-size: var(--faq-question-size-mobile, 14px);
    }

    .product-faq__answer {
      padding-bottom: 20px;
    }

    .product-faq__answer p {
      font-size: var(--faq-answer-size-mobile, 13px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_faq.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.content.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_faq.settings.content.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_1"
    },
    {
      "type": "text",
      "id": "question_1",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "What's included in the box?"
    },
    {
      "type": "textarea",
      "id": "answer_1",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "Each order includes the light fixture, mounting hardware, installation manual, and LED bulb(s). Everything you need for a straightforward setup."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_2"
    },
    {
      "type": "text",
      "id": "question_2",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "Is this light suitable for all outdoor spaces?"
    },
    {
      "type": "textarea",
      "id": "answer_2",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "info": "t:sections.product_faq.settings.faq_items.answer_2_info",
      "default": "Yes, [product_name] is built for all outdoor areas, including patios, driveways, and entryways. Its weather-resistant materials ensure durability in various conditions, but placing it under a covered space during extreme weather can extend its lifespan."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_3"
    },
    {
      "type": "text",
      "id": "question_3",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "How do I choose the right color temperature?"
    },
    {
      "type": "textarea",
      "id": "answer_3",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "We offer three color temperature options: Warm (3000K) for a cozy, relaxing ambiance, Neutral (4000K) for balanced everyday lighting, and Cool (5000K) for bright, focused illumination. Most customers prefer Warm for living spaces and Cool for workspaces."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_4"
    },
    {
      "type": "text",
      "id": "question_4",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "What is the warranty policy?"
    },
    {
      "type": "textarea",
      "id": "answer_4",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "All our lights come with a 2-year warranty covering manufacturing defects. If you experience any issues, our support team will arrange a replacement or repair at no additional cost."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_5"
    },
    {
      "type": "text",
      "id": "question_5",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "Can I install this light myself?"
    },
    {
      "type": "textarea",
      "id": "answer_5",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "While some of our fixtures are designed for easy DIY installation, we recommend hiring a licensed electrician for hardwired installations to ensure safety and compliance with local building codes."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_6"
    },
    {
      "type": "text",
      "id": "question_6",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "What is the return policy?"
    },
    {
      "type": "textarea",
      "id": "answer_6",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "We offer a 30-day risk-free return policy. If you're not completely satisfied, return the product in its original packaging for a full refund. Return shipping is free for domestic orders."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.spacing.header"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:sections.product_faq.settings.spacing.padding_top",
