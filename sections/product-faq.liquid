{%- comment -%}
  Product FAQ Section - Numbered accordion layout
  Supports up to 6 configurable FAQ items via section settings.
{%- endcomment -%}

{%- liquid
  assign faq_count = 0
  if section.settings.question_1 != blank
    assign faq_count = faq_count | plus: 1
  endif
  if section.settings.question_2 != blank
    assign faq_count = faq_count | plus: 1
  endif
  if section.settings.question_3 != blank
    assign faq_count = faq_count | plus: 1
  endif
  if section.settings.question_4 != blank
    assign faq_count = faq_count | plus: 1
  endif
  if section.settings.question_5 != blank
    assign faq_count = faq_count | plus: 1
  endif
  if section.settings.question_6 != blank
    assign faq_count = faq_count | plus: 1
  endif
-%}

{% if faq_count > 0 %}
<div
  class="product-faq full-width"
  style="
    --faq-section-bg: {{ section.settings.section_bg }};
    --faq-padding-top: {{ section.settings.section_padding_top }}px;
    --faq-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --faq-title-color: {{ section.settings.title_color }};
    --faq-title-size: {{ section.settings.title_size }}px;
    --faq-number-color: {{ section.settings.number_color }};
    --faq-question-size: {{ section.settings.question_size }}px;
    --faq-question-size-mobile: {{ section.settings.question_size_mobile }}px;
    --faq-question-color: {{ section.settings.question_color }};
    --faq-answer-size: {{ section.settings.answer_size }}px;
    --faq-answer-size-mobile: {{ section.settings.answer_size_mobile }}px;
    --faq-answer-color: {{ section.settings.answer_color }};
    --faq-border-color: {{ section.settings.border_color }};
    --faq-icon-color: {{ section.settings.icon_color }};
    --faq-bottom-border-color: {{ section.settings.bottom_border_color }};
  "
>
  <div class="product-faq__container">
    {%- if section.settings.heading != blank -%}
      <div class="product-faq__title-wrapper">
        <h2 class="product-faq__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="product-faq__list">
      {%- assign item_index = 0 -%}

      {%- if section.settings.question_1 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_1 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_1 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.question_2 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_2 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_2 | replace: '[product_name]', product.title }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.question_3 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_3 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_3 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.question_4 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_4 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_4 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.question_5 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_5 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_5 }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.question_6 != blank -%}
        {%- assign item_index = item_index | plus: 1 -%}
        <details class="product-faq__item">
          <summary class="product-faq__question">
            <div class="product-faq__question-left">
              <span class="product-faq__number">{% if item_index < 10 %}0{{ item_index }}{% else %}{{ item_index }}{% endif %}</span>
              <span class="product-faq__question-text">{{ section.settings.question_6 }}</span>
            </div>
            <span class="product-faq__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line class="product-faq__icon-h" x1="3" y1="9" x2="15" y2="9"/>
                <line class="product-faq__icon-v" x1="9" y1="3" x2="9" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="product-faq__answer">
            <p>{{ section.settings.answer_6 }}</p>
          </div>
        </details>
      {%- endif -%}
    </div>

    <div class="product-faq__bottom-border"></div>
  </div>
</div>
{% endif %}

{% stylesheet %}
  .product-faq {
    background-color: var(--faq-section-bg, #f7f5f0);
    padding: var(--faq-padding-top, 48px) 0 var(--faq-padding-bottom, 48px) 0;
  }

  .product-faq__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin, 24px);
  }

  /* Title */
  .product-faq__title-wrapper {
    margin-bottom: 40px;
  }

  .product-faq__title {
    font-family: var(--font-body-family), sans-serif;
    font-size: var(--faq-title-size, 12px);
    font-weight: 500;
    color: var(--faq-title-color, #a8a29e);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 0;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--faq-border-color, #d6d3d1);
    line-height: 1;
  }

  /* List */
  .product-faq__list {
    display: flex;
    flex-direction: column;
  }

  /* Each item */
  .product-faq__item {
    border-bottom: 1px solid var(--faq-border-color, #d6d3d1);
  }

  /* Question row */
  .product-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 28px 8px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .product-faq__question::-webkit-details-marker {
    display: none;
  }

  .product-faq__question-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* Number */
  .product-faq__number {
    font-family: var(--font-heading-family), serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--faq-number-color, #a8a29e);
    min-width: 28px;
    flex-shrink: 0;
  }

  /* Question text */
  .product-faq__question-text {
    font-family: var(--font-heading-family), serif;
    font-size: var(--faq-question-size, 22px);
    font-weight: 400;
    color: var(--faq-question-color, #1c1917);
    line-height: 1.3;
  }

  /* Icon */
  .product-faq__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--faq-icon-color, #a8a29e);
  }

  .product-faq__icon-h,
  .product-faq__icon-v {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .product-faq__item[open] .product-faq__icon-v {
    opacity: 0;
    transform: scaleY(0);
  }

  /* Answer */
  .product-faq__answer {
    padding: 0 8px 28px 60px;
  }

  .product-faq__answer p {
    font-family: var(--font-body-family), sans-serif;
    font-size: var(--faq-answer-size, 15px);
    font-weight: 400;
    color: var(--faq-answer-color, #57534e);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  /* Bottom border */
  .product-faq__bottom-border {
    height: 2px;
    background: var(--faq-bottom-border-color, #1c1917);
    margin-top: 0;
  }

  /* Hover */
  .product-faq__question:hover .product-faq__question-text {
    opacity: 0.7;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .product-faq {
      padding: 32px 0;
    }

    .product-faq__container {
      padding: 0 20px;
    }

    .product-faq__title-wrapper {
      margin-bottom: 24px;
    }

    .product-faq__question {
      padding: 22px 4px;
    }

    .product-faq__question-left {
      gap: 20px;
    }

    .product-faq__number {
      font-size: 13px;
      min-width: 22px;
    }

    .product-faq__question-text {
      font-size: var(--faq-question-size-mobile, 18px);
    }

    .product-faq__answer {
      padding: 0 4px 22px 46px;
    }

    .product-faq__answer p {
      font-size: var(--faq-answer-size-mobile, 14px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_faq.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.content.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_faq.settings.content.heading",
      "default": "FREQUENTLY ASKED"
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_1"
    },
    {
      "type": "text",
      "id": "question_1",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "What materials are used in Outlight fixtures?"
    },
    {
      "type": "textarea",
      "id": "answer_1",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "Each order includes the light fixture, mounting hardware, installation manual, and LED bulb(s). Everything you need for a straightforward setup."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_2"
    },
    {
      "type": "text",
      "id": "question_2",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "How do I select the right color temperature?"
    },
    {
      "type": "textarea",
      "id": "answer_2",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "info": "t:sections.product_faq.settings.faq_items.answer_2_info",
      "default": "We offer three color temperature options: Warm (3000K) for a cozy, relaxing ambiance, Neutral (4000K) for balanced everyday lighting, and Cool (5000K) for bright, focused illumination."
    },
    {
      "type": "header",
      "content": "t:sections.product_faq.settings.faq_items.header_3"
    },
    {
      "type": "text",
      "id": "question_3",
      "label": "t:sections.product_faq.settings.faq_items.question",
      "default": "Do you offer custom sizing or finishes?"
    },
    {
      "type": "textarea",
      "id": "answer_3",
      "label": "t:sections.product_faq.settings.faq_items.answer",
      "default": "We currently offer our fixtures in the sizes and finishes listed on each product page. For custom requests, please contact our team directly."
