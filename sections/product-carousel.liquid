    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#1C1917"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Size (desktop)",
      "min": 20,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Size (mobile)",
      "min": 18,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width (desktop)",
      "min": 200,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "card_width_mobile",
