{% comment %}
  Support Center / Help Center – clean, minimal design with search, action cards, and accordion FAQs
{% endcomment %}

<div class="help-center" style="
  --hc-page-bg: {{ section.settings.page_bg_color }};
  --hc-accent: {{ section.settings.accent_color }};
  --hc-breadcrumb-color: {{ section.settings.breadcrumb_color }};
  --hc-title-color: {{ section.settings.title_color }};
  --hc-subtitle-color: {{ section.settings.subtitle_color }};
  --hc-category-title-color: {{ section.settings.category_title_color }};
  --hc-question-color: {{ section.settings.question_color }};
  --hc-answer-color: {{ section.settings.answer_color }};
  --hc-card-bg: {{ section.settings.card_bg_color }};
  --hc-card-border: {{ section.settings.card_border_color }};
  --hc-count-color: {{ section.settings.count_color }};
  --hc-icon-color: {{ section.settings.icon_color }};
  --hc-search-bg: {{ section.settings.search_bg }};
  --hc-search-border: {{ section.settings.search_border }};
  --hc-search-text: {{ section.settings.search_text_color }};
  --hc-search-placeholder: {{ section.settings.search_placeholder_color }};
  --hc-action-bg: {{ section.settings.action_card_bg }};
  --hc-action-border: {{ section.settings.action_card_border }};
  --hc-action-text: {{ section.settings.action_card_text }};
">
  <div class="help-center__container">
    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="help-center__breadcrumb">
      <a href="/" class="help-center__breadcrumb-link">{{ section.settings.breadcrumb_home }}</a>
      <span class="help-center__breadcrumb-sep">/</span>
      <span class="help-center__breadcrumb-current">{{ section.settings.breadcrumb_current }}</span>
    </nav>

    {%- comment -%} Title & Subtitle {%- endcomment -%}
    <h1 class="help-center__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="help-center__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- comment -%} Search Bar {%- endcomment -%}
    <div class="help-center__search">
      <svg class="help-center__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="text"
        class="help-center__search-input"
        placeholder="{{ section.settings.search_placeholder }}"
        data-hc-search
      />
    </div>

    {%- comment -%} Action Buttons {%- endcomment -%}
    <div class="help-center__actions">
      {%- if section.settings.track_button_text != blank -%}
        <a href="{{ section.settings.track_button_link }}" class="help-center__action-card">
          <svg class="help-center__action-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 10h20"/>
            <path d="M6 16h4"/>
          </svg>
          <span class="help-center__action-label">{{ section.settings.track_button_text }}</span>
        </a>
      {%- endif -%}
      {%- if section.settings.return_button_text != blank -%}
        <a href="{{ section.settings.return_button_link }}" class="help-center__action-card">
          <svg class="help-center__action-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 14l-4-4 4-4"/>
            <path d="M5 10h11a4 4 0 0 1 0 8h-1"/>
          </svg>
          <span class="help-center__action-label">{{ section.settings.return_button_text }}</span>
        </a>
      {%- endif -%}
      {%- if section.settings.contact_button_text != blank -%}
        <a href="{{ section.settings.contact_button_link }}" class="help-center__action-card">
          <svg class="help-center__action-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="14" rx="2"/>
            <path d="M8 12h.01M12 12h.01M16 12h.01"/>
          </svg>
          <span class="help-center__action-label">{{ section.settings.contact_button_text }}</span>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} FAQ Categories {%- endcomment -%}
    {%- assign categories = section.blocks | where: "type", "tab" -%}
    {%- if categories.size > 0 -%}
      <div class="help-center__categories">
        {%- for block in categories -%}
          {%- comment -%} Count questions in this category {%- endcomment -%}
          {%- assign q_count = 0 -%}
          {%- if block.settings.question_1 != blank -%}{%- assign q_count = q_count | plus: 1 -%}{%- endif -%}
          {%- if block.settings.question_2 != blank -%}{%- assign q_count = q_count | plus: 1 -%}{%- endif -%}
          {%- if block.settings.question_3 != blank -%}{%- assign q_count = q_count | plus: 1 -%}{%- endif -%}
          {%- if block.settings.question_4 != blank -%}{%- assign q_count = q_count | plus: 1 -%}{%- endif -%}
          {%- if block.settings.question_5 != blank -%}{%- assign q_count = q_count | plus: 1 -%}{%- endif -%}

          <div class="help-center__category" data-hc-category {{ block.shopify_attributes }}>
            {%- comment -%} Category Header {%- endcomment -%}
            <div class="help-center__category-header">
              <div class="help-center__category-left">
                <span class="help-center__category-bar"></span>
                <h2 class="help-center__category-title">{{ block.settings.tab_title }}</h2>
              </div>
              <span class="help-center__category-count">{{ q_count }} {{ q_count | pluralize: 'article', 'articles' }}</span>
            </div>

            {%- comment -%} FAQ Accordion Items {%- endcomment -%}
            <div class="help-center__faq-list">
              {%- if block.settings.question_1 != blank -%}
                <details class="help-center__faq-item" data-hc-faq>
                  <summary class="help-center__faq-header">
                    <span class="help-center__faq-question">{{ block.settings.question_1 }}</span>
                    <span class="help-center__faq-toggle"></span>
                  </summary>
                  <div class="help-center__faq-answer">
                    <p>{{ block.settings.answer_1 }}</p>
                  </div>
                </details>
              {%- endif -%}
              {%- if block.settings.question_2 != blank -%}
                <details class="help-center__faq-item" data-hc-faq>
                  <summary class="help-center__faq-header">
                    <span class="help-center__faq-question">{{ block.settings.question_2 }}</span>
                    <span class="help-center__faq-toggle"></span>
                  </summary>
                  <div class="help-center__faq-answer">
                    <p>{{ block.settings.answer_2 }}</p>
                  </div>
                </details>
              {%- endif -%}
              {%- if block.settings.question_3 != blank -%}
                <details class="help-center__faq-item" data-hc-faq>
                  <summary class="help-center__faq-header">
                    <span class="help-center__faq-question">{{ block.settings.question_3 }}</span>
                    <span class="help-center__faq-toggle"></span>
                  </summary>
                  <div class="help-center__faq-answer">
                    <p>{{ block.settings.answer_3 }}</p>
                  </div>
                </details>
              {%- endif -%}
              {%- if block.settings.question_4 != blank -%}
                <details class="help-center__faq-item" data-hc-faq>
                  <summary class="help-center__faq-header">
                    <span class="help-center__faq-question">{{ block.settings.question_4 }}</span>
                    <span class="help-center__faq-toggle"></span>
                  </summary>
                  <div class="help-center__faq-answer">
                    <p>{{ block.settings.answer_4 }}</p>
                  </div>
                </details>
              {%- endif -%}
              {%- if block.settings.question_5 != blank -%}
                <details class="help-center__faq-item" data-hc-faq>
                  <summary class="help-center__faq-header">
                    <span class="help-center__faq-question">{{ block.settings.question_5 }}</span>
                    <span class="help-center__faq-toggle"></span>
                  </summary>
                  <div class="help-center__faq-answer">
                    <p>{{ block.settings.answer_5 }}</p>
                  </div>
                </details>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} No results message for search {%- endcomment -%}
    <div class="help-center__no-results" data-hc-no-results style="display: none;">
      <p>No matching questions found. Try a different search term.</p>
    </div>
  </div>
</div>

{% stylesheet %}
  .help-center {
    background-color: var(--hc-page-bg, #f7f5f0);
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    padding: 2rem 1.25rem 3rem;
  }

  .help-center__container {
    max-width: 640px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .help-center__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-body-family), sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hc-breadcrumb-color, #a8a29e);
  }

  .help-center__breadcrumb-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .help-center__breadcrumb-link:hover {
    color: var(--hc-accent, #d97706);
  }

  .help-center__breadcrumb-sep {
    color: inherit;
    opacity: 0.5;
  }

  .help-center__breadcrumb-current {
    color: inherit;
  }

  /* Title */
  .help-center__title {
    font-family: var(--font-heading-family), serif;
    font-size: 36px;
    font-weight: 400;
    color: var(--hc-title-color, #1c1917);
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  /* Subtitle */
  .help-center__subtitle {
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--hc-subtitle-color, #78716c);
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  /* Search Bar */
  .help-center__search {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .help-center__search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--hc-search-placeholder, #a8a29e);
    pointer-events: none;
  }

  .help-center__search-input {
    width: 100%;
    padding: 14px 20px 14px 48px;
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--hc-search-text, #1c1917);
    background-color: var(--hc-search-bg, #ffffff);
    border: 1px solid var(--hc-search-border, #e5e2db);
    border-radius: 50px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .help-center__search-input::placeholder {
    color: var(--hc-search-placeholder, #a8a29e);
    font-weight: 400;
  }

  .help-center__search-input:focus {
    border-color: var(--hc-accent, #d97706);
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.1);
  }

  /* Action Cards */
  .help-center__actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 2.5rem;
  }

  .help-center__action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 20px 12px;
    background-color: var(--hc-action-bg, #ffffff);
    border: 1px solid var(--hc-action-border, #e5e2db);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    cursor: pointer;
  }

  .help-center__action-card:hover {
    border-color: var(--hc-accent, #d97706);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .help-center__action-icon {
    color: var(--hc-accent, #d97706);
    flex-shrink: 0;
  }

  .help-center__action-label {
    font-family: var(--font-body-family), sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--hc-action-text, #1c1917);
  }

  /* Categories */
  .help-center__categories {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Category Header */
  .help-center__category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding: 0 4px;
  }

  .help-center__category-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .help-center__category-bar {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--hc-accent, #d97706);
    flex-shrink: 0;
  }

  .help-center__category-title {
    font-family: var(--font-body-family), sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hc-category-title-color, #d97706);
    margin: 0;
    line-height: 1;
  }

  .help-center__category-count {
    font-family: var(--font-body-family), sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--hc-count-color, #a8a29e);
  }

  /* FAQ List */
  .help-center__faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* FAQ Item */
  .help-center__faq-item {
    background-color: var(--hc-card-bg, #ffffff);
    border: 1px solid var(--hc-card-border, #e5e2db);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .help-center__faq-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .help-center__faq-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    gap: 1rem;
  }

  .help-center__faq-header::-webkit-details-marker {
    display: none;
  }

  .help-center__faq-question {
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--hc-question-color, #1c1917);
    line-height: 1.4;
    font-style: italic;
  }

  /* Toggle Plus Icon */
  .help-center__faq-toggle {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .help-center__faq-toggle::before,
  .help-center__faq-toggle::after {
    content: '';
    position: absolute;
    background-color: var(--hc-icon-color, #a8a29e);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .help-center__faq-toggle::before {
    width: 14px;
    height: 1.5px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .help-center__faq-toggle::after {
    width: 1.5px;
    height: 14px;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .help-center__faq-item[open] .help-center__faq-toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .help-center__faq-item[open] .help-center__faq-header {
    border-bottom: 1px solid var(--hc-card-border, #e5e2db);
  }

  /* FAQ Answer */
  .help-center__faq-answer {
    padding: 16px 20px 20px;
  }

  .help-center__faq-answer p {
    font-family: var(--font-body-family), sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: var(--hc-answer-color, #57534e);
    margin: 0;
  }

  /* No Results */
  .help-center__no-results {
    text-align: center;
    padding: 2rem 1rem;
  }

  .help-center__no-results p {
    font-family: var(--font-body-family), sans-serif;
    font-size: 15px;
    color: var(--hc-subtitle-color, #78716c);
    margin: 0;
  }

  /* Hidden class for search filtering */
  .help-center__faq-item--hidden {
    display: none;
  }

  .help-center__category--hidden {
    display: none;
  }

  /* Desktop */
  @media screen and (min-width: 769px) {
    .help-center {
      padding: 2.5rem 2rem 4rem;
    }

    .help-center__title {
      font-size: 42px;
    }
  }

  /* Mobile adjustments */
  @media screen and (max-width: 768px) {
    .help-center {
      padding: 1.5rem 1rem 2.5rem;
    }

    .help-center__title {
      font-size: 30px;
    }

    .help-center__subtitle {
      font-size: 14px;
    }

    .help-center__search-input {
      padding: 12px 16px 12px 44px;
      font-size: 14px;
    }

    .help-center__actions {
      gap: 8px;
    }

    .help-center__action-card {
      padding: 16px 8px;
      gap: 8px;
    }

    .help-center__action-icon {
      width: 24px;
      height: 24px;
    }

    .help-center__action-label {
      font-size: 13px;
    }

    .help-center__faq-header {
      padding: 14px 16px;
    }

    .help-center__faq-question {
      font-size: 14px;
    }

    .help-center__faq-answer {
      padding: 12px 16px 16px;
    }

    .help-center__faq-answer p {
      font-size: 13px;
    }

    .help-center__category-title {
      font-size: 12px;
    }

    .help-center__category-count {
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var searchInput = document.querySelector('[data-hc-search]');
    if (!searchInput) return;

    searchInput.addEventListener('input', function() {
      var query = this.value.toLowerCase().trim();
      var categories = document.querySelectorAll('[data-hc-category]');
      var noResults = document.querySelector('[data-hc-no-results]');
      var anyVisible = false;

      categories.forEach(function(category) {
        var items = category.querySelectorAll('[data-hc-faq]');
        var categoryHasVisible = false;

        items.forEach(function(item) {
          var question = item.querySelector('.help-center__faq-question');
          var answer = item.querySelector('.help-center__faq-answer');
          var text = (question ? question.textContent : '') + ' ' + (answer ? answer.textContent : '');

          if (query === '' || text.toLowerCase().indexOf(query) !== -1) {
            item.classList.remove('help-center__faq-item--hidden');
            categoryHasVisible = true;
          } else {
            item.classList.add('help-center__faq-item--hidden');
          }
        });

        if (categoryHasVisible) {
          category.classList.remove('help-center__category--hidden');
          anyVisible = true;
        } else {
          category.classList.add('help-center__category--hidden');
        }
      });

      if (noResults) {
        noResults.style.display = anyVisible || query === '' ? 'none' : 'block';
      }
    });
  })();
{% endjavascript %}

